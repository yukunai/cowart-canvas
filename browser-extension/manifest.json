{
  "manifest_version": 3,
  "name": "Cowart Canvas Launcher",
  "description": "Open Cowart Canvas, Image, Design, Video, and Text pages from any browser window.",
  "version": "0.1.0",
  "action": {
    "default_title": "Cowart Canvas",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "storage"]
}
