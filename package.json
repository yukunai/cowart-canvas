{
  "name": "cowart-canvas",
  "version": "0.1.0",
  "private": false,
  "description": "Local browser canvas for marking image edits and preparing image-to-video tasks.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 43219",
    "start": "vite --host 127.0.0.1 --port 43219",
    "open": "scripts/open-cowart-canvas.sh",
    "open:extension": "open browser-extension",
    "install:mac": "scripts/install-cowart-canvas-launch-agent.sh",
    "uninstall:mac": "scripts/uninstall-cowart-canvas-launch-agent.sh",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
