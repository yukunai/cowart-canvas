# Copy this file to .env.local, then fill only the providers you want to use.
# After editing .env.local, restart the dev server.

# Kling / 可灵
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_VIDEO_MODEL=kling-v1-6
# KLING_BASE_URL=https://api.klingai.com
KLING_IMAGE_MODEL=kling-image-v1
# KLING_IMAGE_ENDPOINT=https://api.klingai.com/v1/images/generations

# Volcengine Ark / 火山方舟
ARK_API_KEY=
# Optional. Defaults to doubao-seedance-2-0-260128 when left blank.
ARK_VIDEO_MODEL=
# ARK_VIDEO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
# Optional image generation/editing.
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
# ARK_IMAGE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations

# Alibaba DashScope / 阿里万象
DASHSCOPE_API_KEY=
DASHSCOPE_VIDEO_MODEL=wan2.6-i2v-flash
# DASHSCOPE_VIDEO_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis
DASHSCOPE_IMAGE_MODEL=wan2.7-image-pro
# DASHSCOPE_IMAGE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_IMAGE_TASK_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/tasks/{task_id}

# Runway
RUNWAY_API_KEY=
RUNWAY_VIDEO_MODEL=gen4_turbo
RUNWAY_API_VERSION=2024-11-06
# RUNWAY_VIDEO_ENDPOINT=https://api.dev.runwayml.com/v1/image_to_video

# Luma
LUMA_API_KEY=
LUMA_VIDEO_MODEL=ray-2
# LUMA_VIDEO_ENDPOINT=https://api.lumalabs.ai/dream-machine/v1/generations

# fal.ai
FAL_KEY=
FAL_VIDEO_MODEL=fal-ai/kling-video/v2.1/standard/image-to-video
# FAL_VIDEO_ENDPOINT=https://queue.fal.run/fal-ai/kling-video/v2.1/standard/image-to-video
FAL_IMAGE_MODEL=fal-ai/flux-pro/kontext/max/multi
# FAL_IMAGE_ENDPOINT=https://fal.run/fal-ai/flux-pro/kontext/max/multi

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_VERSION=
# REPLICATE_VIDEO_ENDPOINT=https://api.replicate.com/v1/predictions
